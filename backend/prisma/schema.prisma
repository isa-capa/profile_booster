generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum ApplicationStatus {
  DRAFT
  APPLIED
  INTERVIEW
  REJECTED
  OFFER
}

enum DocumentType {
  CV_PDF
  CV_HTML
  BASE_CV_PDF
  OTHER
}

enum AITaskType {
  JOB_ANALYSIS
  CV_OPTIMIZATION
  COMPANY_BRIEF
  PREP_PLAN
}

enum AiStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// Models
model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  profile      UserProfile?
  applications Application[]
  auditLogs    AuditLog[]
  usageQuotas  UsageQuota[]
}

model UserProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String?
  headline     String?
  summary      String?
  baseCvText   String?
  baseCvJson   Json?
  updatedAt    DateTime @updatedAt
}

model Application {
  id              String            @id @default(uuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName     String
  jobTitle        String
  jobLink         String?
  statusEnum      ApplicationStatus @default(DRAFT)
  createdAt       DateTime          @default(now())

  jobPost         JobPost?
  cvVersions      CvVersion[]
  atsScore        AtsScore?
  companyBrief    CompanyBrief?
  prepPlan        PrepPlan?
  aiRuns          AiRun[]
  documents       Document[]

  @@index([userId])
}

model JobPost {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  jdText        String
  extractedJson Json?
  createdAt     DateTime    @default(now())
}

model CvVersion {
  id                   String      @id @default(uuid())
  applicationId        String
  application          Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  versionNumber        Int
  cvText               String?
  cvHtml               String?
  keywordsUsedJson     Json?
  changesSummary       String?
  atsScoreSnapshotJson Json?
  createdAt            DateTime    @default(now())

  @@index([applicationId])
}

model AtsScore {
  id                      String      @id @default(uuid())
  applicationId           String      @unique
  application             Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scoreTotal              Float
  missingKeywordsJson     Json?
  recommendedKeywordsJson Json?
  breakdownJson           Json?
  createdAt               DateTime    @default(now())
}

model CompanyBrief {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  briefJson     Json?
  createdAt     DateTime    @default(now())
}

model PrepPlan {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  planJson      Json?
  createdAt     DateTime    @default(now())
}

model AiRun {
  id             String      @id @default(uuid())
  applicationId  String
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  taskTypeEnum   AITaskType
  providerName   String
  promptVersion  String
  modelName      String?
  inputHash      String?
  outputJson     Json?
  tokensEstimate Int?
  latencyMs      Int?
  status         AiStatus    @default(PENDING)
  errorMessage   String?
  createdAt      DateTime    @default(now())

  @@index([applicationId])
}

model Document {
  id            String       @id @default(uuid())
  applicationId String
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  typeEnum      DocumentType
  storageKey    String       @unique
  mimeType      String
  sizeBytes     Int
  createdAt     DateTime     @default(now())

  @@index([applicationId])
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       String
  entityType   String
  entityId     String
  metadataJson Json?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model UsageQuota {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate    DateTime
  generationsUsed  Int      @default(0)
  generationsLimit Int      @default(20)

  @@index([userId, weekStartDate])
}
